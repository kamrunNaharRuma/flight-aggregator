APP_NAME="Flight Aggregator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=flight_aggregator
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ─── Cache (Redis) ────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Queue & Session ──────────────────────────────────────────────────────────
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Mail (not used) ─────────────────────────────────────────────────────────
MAIL_MAILER=array
